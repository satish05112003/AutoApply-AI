# ==============================================================================
# AutoApply AI — Global Environment Configuration Example
# Copy this file to:
#  1. backend/.env (and customize values)
#  2. frontend/.env.local (only needs NEXT_PUBLIC_API_URL and NEXT_PUBLIC_WS_URL)
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# BACKEND CONFIGURATIONS
# ──────────────────────────────────────────────────────────────────────────────

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autoapply_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Settings (Celery broker and cache)
REDIS_URL=redis://localhost:6379/0

# JWT Auth Settings
JWT_SECRET_KEY=generate_a_very_long_secure_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Storage Settings
STORAGE_TYPE=local  # Options: 'local' or 'minio'
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=resumes

# LLM Providers (Configure at least one for parsing and screening answer generation)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_FALLBACK_ENABLED=true

# Embedding Model (For semantic deduplication and vector search)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector DB Settings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Playwright Browser Pool Settings
PLAYWRIGHT_HEADLESS=true
BROWSER_POOL_SIZE=3
BROWSER_TIMEOUT_MS=30000

# Google Sheets Integration (Service Account JSON text)
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}
SHEETS_BATCH_SIZE=50
SHEETS_BATCH_FLUSH_INTERVAL_SECONDS=30

# Notification & Recruiter Email Tracker Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Agent Behavior Defaults
MAX_APPLICATIONS_PER_USER_PER_DAY=500
MIN_MATCH_SCORE_TO_APPLY=65
AUTO_APPLY_ENABLED_BY_DEFAULT=false

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATIONS (Next.js client)
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
